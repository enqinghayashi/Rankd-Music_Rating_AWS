# Flask
SECRET_KEY=change-me

# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
# Local example: http://127.0.0.1:5000/auth
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5000/auth

# Database (optional)
# SQLite is used by default; for Postgres (e.g. AWS RDS), set DATABASE_URL.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
